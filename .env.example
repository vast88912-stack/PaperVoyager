# Copy this file to .env and fill in the provider you want to use.
# Never commit .env or real API keys.

# Gemini / Google GenAI
CODEGEN_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-exp

# OpenAI-compatible providers
# CODEGEN_PROVIDER=openai
# CODEGEN_BASE_URL=https://api.openai.com/v1
# CODEGEN_API_KEY=
# CODEGEN_MODEL=
# CODEGEN_USE_RESPONSES=false

# Optional generation controls
CODEGEN_TEMPERATURE=0.2
CODEGEN_MAX_OUTPUT_TOKENS=8192

